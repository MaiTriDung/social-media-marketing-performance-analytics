Tạo bảng Fact_PostPerformance từ lớp Staging
Hệ cơ sở dữ liệu: Google BigQuery

SELECT
  #1. IDENTIFIER KEYS
  s.Post_key AS post_key,
  s.Post_ID AS post_id,
  
  #2. DIMENSION FOREIGN KEYS
  #Chuẩn hóa Platform ID để Join với Dim_Platform
  CASE
    WHEN LOWER(TRIM(s.Platform)) = 'facebook' THEN 'PLT_FB'
    WHEN LOWER(TRIM(s.Platform)) = 'tiktok' THEN 'PLT_TT'
    WHEN LOWER(TRIM(s.Platform)) = 'instagram' THEN 'PLT_IG'
    WHEN LOWER(TRIM(s.Platform)) IN ('x.com','x','twitter') THEN 'PLT_X'
    WHEN LOWER(TRIM(s.Platform)) = 'youtube' THEN 'PLT_YT'
    WHEN LOWER(TRIM(s.Platform)) = 'linkedin' THEN 'PLT_LI'
    ELSE CONCAT('PLT_', UPPER(REGEXP_REPLACE(TRIM(s.Platform), r'[^A-Za-z0-9]+', '')))
  END AS platform_id,
  
  #Tạo Content ID bằng cách gộp tổ hợp Content_Type | Category | Post_Type
  SUBSTR(
    TO_HEX(MD5(CONCAT(
      IFNULL(UPPER(TRIM(s.Content_Type)),''), '|',
      IFNULL(UPPER(TRIM(s.Content_Category)),''), '|',
      IFNULL(UPPER(TRIM(s.Post_Type)),'')
    ))), 1, 10
  ) AS content_id,
  
  #Date ID format YYYYMMDD để Join với Dim_Date
  FORMAT_DATE('%Y%m%d', CAST(s.Post_Date_Clean AS DATE)) AS date_id,
  
  #Tạo Geo ID bằng cách gộp tổ hợp Region | Latitude | Longitude
  SUBSTR(
    TO_HEX(MD5(CONCAT(
      IFNULL(UPPER(TRIM(s.Region)),''), '|',
      IFNULL(CAST(s.Latitude AS STRING),''), '|',
      IFNULL(CAST(s.Longitude AS STRING),'')
    ))), 1, 10
  ) AS geo_id,
  
  #3. TIME VARIABLES
  CAST(s.Post_Date_Clean AS DATE) AS post_date_clean,
  s.Post_Hour_Clean AS post_hour_clean,
  s.Post_Published_At AS post_published_at,
  
  #4. PERFORMANCE METRICS (FACTS)
  s.Impressions, s.Views, s.Engagement, s.Likes, s.Comments, 
  s.Shares, s.Video_Views, s.Live_Stream_Views, s.Clicks,
  s.Click_Through_Rate, s.Has_click_data, s.Traffic_scope, 
  s.Engagement_Rate, s.engagement_rate_num, s.Engagement_Level,
  
  #5. Các cột gốc dung để đối chiếu dữ liệu (Giữ lại để validate Data Model)
  s.Platform, s.Content_Type, s.Content_Category, s.Post_Type, s.Main_Hashtag

FROM `jda-k1.practice_data_pipeline.social_stg_dedup` s;

